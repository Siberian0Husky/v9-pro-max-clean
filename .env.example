# ── Frontend (safe to expose, prefixed NEXT_PUBLIC_) ──────────────
# Get your free key at: https://web3forms.com (30 seconds, no credit card)
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_access_key

# ── Backend (Cloudflare Pages Environment Variables — NEVER commit) ──
# OpenAI — for AI lead scoring in /functions/ai.js and /functions/rfq.js
OPENAI_API_KEY=sk-...

# SendGrid — for email notifications on new RFQs
SENDGRID_API_KEY=SG....
NOTIFY_EMAIL=sales@globnexis.com

# Google Ads — for /functions/ads_optimizer.js
GOOGLE_ADS_KEY=your_google_ads_developer_token

# Supabase — optional: for storing RFQ records in a database
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# WhatsApp Business API — optional: for WhatsApp lead notifications
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_id
